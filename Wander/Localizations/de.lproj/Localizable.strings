/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "Standort nicht erkannt? (Fehler 12)";
"error12.intro" = "Pokémon GO meldet „Standort konnte nicht ermittelt werden (12)“, wenn das Spiel keine saubere GPS-Position bekommt. Wander glättet deine Bewegung bereits, damit sie dem Spiel nicht in die Quere kommt – diese Schritte beheben den Rest.";
"error12.step.location_on.title" = "Ortungsdienste aktivieren";
"error12.step.location_on.detail" = "iPhone-Einstellungen → Datenschutz & Sicherheit → Ortungsdienste → EIN, und Pokémon GO → Beim Verwenden der App einstellen. Die Ortungsdienste müssen aktiviert sein, damit der eingespielte Standort das Spiel erreicht.";
"error12.step.refresh.title" = "Nach dem Teleportieren die Position auffrischen";
"error12.step.refresh.detail" = "Schalte die Ortungsdienste für ~3 Sekunden aus und wieder ein (Einstellungen → Datenschutz & Sicherheit → Ortungsdienste). So zwingst du iOS, an deinem neuen Ort eine frische Position zu ermitteln.";
"error12.step.cooldown.title" = "Abklingzeit nach dem INTERAGIEREN einhalten";
"error12.step.cooldown.detail" = "Der Abklingzeit-Timer wird durch Aktionen ausgelöst – ein Pokémon fangen, einen Stopp drehen, eine Beere geben, kämpfen, in einer Arena platzieren – nicht durch das Teleportieren selbst. Du kannst dich also frei teleportieren, aber warte die Abklingzeit ab, bevor du das nächste Mal interagierst.";
"error12.step.smooth.title" = "Bewege dich flüssig; nicht schnell hintereinander teleportieren";
"error12.step.smooth.detail" = "Wenn Fehler 12 während der Bewegung auftaucht, halte an, warte ein paar Sekunden, bis sich die Position stabilisiert hat, und mach dann weiter. Vermeide eine Flut winziger Teleports.";
"error12.step.keep_running.title" = "Wander weiterlaufen lassen";
"error12.step.keep_running.detail" = "Lass die App beim Spielen geöffnet und den Tunnel verbunden – bricht der Tunnel ab, verliert das Spiel sofort die Position.";
"error12.cooldown.header" = "Interaktions-Abklingzeit nach Entfernung";
"error12.cooldown.disclaimer" = "Schätzungen der Community, keine offiziellen Niantic-Werte.";
"error12.footer.discord" = "Immer noch nicht weiter? Sag uns im Discord-Kanal #bug-reports Bescheid.";
"stabilizer.title" = "Langstrecken-Stabilisator (Beta)";
"stabilizer.intro" = "Experimentell. Hilft, dass ein WEITER Teleport stabil bleibt, statt zurückzudriften.";
"stabilizer.what.header" = "Was das bewirkt";
"stabilizer.what.body" = "Wenn du dich weit teleportierst (mehr als etwa 20 km), zieht iOS deinen Standort manchmal zurück zu deinem echten Aufenthaltsort – anhand von nahegelegenem WLAN und Mobilfunkmasten – sodass ein weit entfernter Ort driftet oder zurückspringt.\n\nDiese Funktion installiert ein DNS-Profil, das dein DNS über Wanders Server leitet und Apples Standort-Nachschlagedienst blockiert. Ist dieser Abruf blockiert, kann iOS dich nicht korrigieren, und ein weiter Teleport bleibt stabil. Das ist nur für das DRIFTEN bei weiten Teleports gedacht.";
"stabilizer.warning.header" = "Zuerst lesen";
"stabilizer.warning.beta" = "Beta & experimentell – hilft möglicherweise nicht auf jedem Gerät oder jeder iOS-Version.";
"stabilizer.warning.dns" = "Solange installiert, läuft dein GESAMTES DNS über Wanders Server. Das kann Apple-Dienste beeinträchtigen (iCloud, Karten, App Store, Wo ist?).";
"stabilizer.warning.off" = "Schalte es AUS, wenn du fertig bist.";
"stabilizer.warning.error12" = "Das behebt „Fehler 12“ NICHT. Dafür siehe die Hilfe zu Fehler 12 (Einstellungen → Hilfe → Standort nicht erkannt).";
"stabilizer.signin.needed" = "Melde dich bei deinem Wander-Konto an, um das einzurichten.";
"stabilizer.signin.button" = "Anmelden";
"stabilizer.install.fetching" = "Profil wird vorbereitet…";
"stabilizer.install.button" = "Profil installieren";
"stabilizer.next.header" = "Nächste Schritte";
"stabilizer.next.body" = "Safari lädt das Profil herunter. Dann:\n\n1. Einstellungen → Profil geladen → Installieren (iOS fragt eventuell nach deinem Code).\n\n2. Nach der Installation: Einstellungen → Allgemein → VPN & Geräteverwaltung → DNS → stelle sicher, dass „Wander Long-Distance Stabilizer“ ausgewählt ist.\n\n3. Schalte dann die Ortungsdienste für etwa 3 Sekunden aus und wieder ein.";
"stabilizer.remove.header" = "Ausschalten / entfernen";
"stabilizer.remove.body" = "Einstellungen → Allgemein → VPN & Geräteverwaltung → tippe auf „Wander Long-Distance Stabilizer (Beta)“ → Profil entfernen.\n\nEntferne es immer, wenn du keine weiten Teleports nutzt – es leitet dein gesamtes DNS über Wanders Server, sodass es Apple-Dienste beeinträchtigen kann, wenn es aktiv bleibt.";
"stabilizer.error.offline" = "Für die Einrichtung brauchst du eine Internetverbindung.";
"stabilizer.error.build" = "Die Anfrage konnte nicht erstellt werden. Bitte versuche es erneut.";
"stabilizer.error.unavailable" = "Derzeit nicht verfügbar – bitte versuche es später erneut.";
"stabilizer.error.network" = "Wander konnte nicht erreicht werden – prüfe deine Verbindung und versuche es erneut.";
"stabilizer.error.safari" = "Safari konnte nicht geöffnet werden, um das Profil herunterzuladen. Bitte versuche es erneut.";
