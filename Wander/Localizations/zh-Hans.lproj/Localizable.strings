/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "无法检测到位置？（错误 12）";
"error12.intro" = "Pokémon GO 的“无法检测到位置 (12)”表示游戏没有获得干净的 GPS 定位。Wander 已经让你的移动更平滑，不会与游戏冲突——以下步骤解决其余问题。";
"error12.step.location_on.title" = "开启定位服务";
"error12.step.location_on.detail" = "iPhone 设置 → 隐私与安全性 → 定位服务 → 打开，并将 Pokémon GO 设为“使用 App 期间”。只有开启定位服务，注入的位置才能传到游戏中。";
"error12.step.refresh.title" = "传送后，刷新定位";
"error12.step.refresh.detail" = "将定位服务关闭约 3 秒，然后重新打开（设置 → 隐私与安全性 → 定位服务）。这会强制 iOS 在你的新位置重新获取定位。";
"error12.step.cooldown.title" = "遵守“互动”后的冷却时间";
"error12.step.cooldown.detail" = "冷却计时由操作触发——抓宝可梦、转补给站、喂树果、对战、放入道馆——而不是传送本身。所以你可以自由传送，但在下一次互动前请等待冷却结束。";
"error12.step.smooth.title" = "平滑移动，不要快速连续传送";
"error12.step.smooth.detail" = "如果移动时弹出错误 12，先停下，等几秒让定位稳定，然后再继续。避免连续的小幅传送。";
"error12.step.keep_running.title" = "保持 Wander 运行";
"error12.step.keep_running.detail" = "游戏时让 App 保持打开、隧道保持连接——一旦隧道断开，游戏会立即丢失定位。";
"error12.cooldown.header" = "按距离的互动冷却时间";
"error12.cooldown.disclaimer" = "社区估算值，非 Niantic 官方数据。";
"error12.footer.discord" = "还是卡住了？请在 Discord 的 #bug-reports 频道告诉我们。";
"stabilizer.title" = "远距离稳定器（Beta）";
"stabilizer.intro" = "实验性功能。帮助远距离传送保持稳定，而不是漂移回原处。";
"stabilizer.what.header" = "此功能的作用";
"stabilizer.what.body" = "当你远距离传送时（超过约 20 公里），iOS 有时会利用附近的 Wi-Fi 和基站，把你的位置拉回你真正所在的地方，导致远处的位置漂移或弹回。\n\n此功能会安装一个 DNS 描述文件，将你的 DNS 通过 Wander 的服务器转发，从而屏蔽 Apple 的位置查询服务。查询被屏蔽后，iOS 无法纠正你的位置，远距离传送就能保持稳定。它仅用于远距离传送的“漂移”问题。";
"stabilizer.warning.header" = "请先阅读";
"stabilizer.warning.beta" = "Beta 且为实验性功能——不一定在所有设备或 iOS 版本上都有效。";
"stabilizer.warning.dns" = "安装期间，你的所有 DNS 都会经过 Wander 的服务器。这可能影响 Apple 服务（iCloud、地图、App Store、查找）。";
"stabilizer.warning.off" = "用完后请将其关闭。";
"stabilizer.warning.error12" = "此功能不能解决“错误 12”。若要解决，请查看错误 12 帮助（设置 → 帮助 → 无法检测到位置）。";
"stabilizer.signin.needed" = "登录你的 Wander 账户以进行设置。";
"stabilizer.signin.button" = "登录";
"stabilizer.install.fetching" = "正在准备描述文件…";
"stabilizer.install.button" = "安装描述文件";
"stabilizer.next.header" = "后续步骤";
"stabilizer.next.body" = "Safari 正在下载描述文件。然后：\n\n1. 设置 → 已下载描述文件 → 安装（iOS 可能会要求输入密码）。\n\n2. 安装后：设置 → 通用 → VPN 与设备管理 → DNS → 确保已选择“Wander Long-Distance Stabilizer”。\n\n3. 然后将定位服务关闭约 3 秒，再重新打开。";
"stabilizer.remove.header" = "关闭 / 移除";
"stabilizer.remove.body" = "设置 → 通用 → VPN 与设备管理 → 点按“Wander Long-Distance Stabilizer (Beta)”→ 移除描述文件。\n\n不使用远距离传送时请随时移除它——它会把你所有的 DNS 都经过 Wander 的服务器，因此一直开着可能影响 Apple 服务。";
