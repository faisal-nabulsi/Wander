/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "位置情報を検出できませんか？（エラー12）";
"error12.intro" = "Pokémon GOの「位置情報を検出できませんでした（12）」は、ゲームがクリーンなGPSを取得できなかったことを意味します。Wanderはすでに動きを滑らかにしてゲームと干渉しないようにしています。以下の手順で残りを解決しましょう。";
"error12.step.location_on.title" = "位置情報サービスをオンにする";
"error12.step.location_on.detail" = "iPhoneの設定 → プライバシーとセキュリティ → 位置情報サービス → オン、さらにPokémon GO → このAppの使用中のみに設定します。挿入された位置情報をゲームに届けるには、位置情報サービスがオンである必要があります。";
"error12.step.refresh.title" = "テレポート後は位置情報を更新する";
"error12.step.refresh.detail" = "位置情報サービスを約3秒オフにしてから、再度オンにします（設定 → プライバシーとセキュリティ → 位置情報サービス）。これでiOSが新しい場所で位置情報を取得し直します。";
"error12.step.cooldown.title" = "「操作」後のクールダウンを守る";
"error12.step.cooldown.detail" = "クールダウンのタイマーは、ポケモンを捕まえる、ポケストップを回す、きのみをあげる、バトルする、ジムに配置するといった操作で始まります。テレポート自体では始まりません。ですからテレポートは自由に行えますが、次の操作の前にクールダウンが終わるのを待ちましょう。";
"error12.step.smooth.title" = "滑らかに移動し、連続テレポートを避ける";
"error12.step.smooth.detail" = "移動中にエラー12が出たら、いったん止まり、位置情報が落ち着くまで数秒待ってから続けます。小刻みなテレポートの連発は避けてください。";
"error12.step.keep_running.title" = "Wanderを起動したままにする";
"error12.step.keep_running.detail" = "プレイ中はトンネルを接続したままアプリを開いておきます。トンネルが切れると、ゲームは即座に位置情報を失います。";
"error12.cooldown.header" = "距離ごとの操作クールダウン";
"error12.cooldown.disclaimer" = "コミュニティによる推定値で、Niantic公式の値ではありません。";
"error12.footer.discord" = "まだ解決しませんか？ Discordの#bug-reportsチャンネルで教えてください。";
"stabilizer.title" = "長距離スタビライザー（ベータ）";
"stabilizer.intro" = "実験的機能。遠くへのテレポートが元に戻らず安定するよう補助します。";
"stabilizer.what.header" = "この機能について";
"stabilizer.what.body" = "遠くへテレポートすると（およそ20 km超）、iOSが近くのWi-Fiや携帯電話の基地局を使って、あなたの位置を実際の居場所へ引き戻すことがあり、遠い地点がずれたり元に戻ったりします。\n\nこの機能は、DNSをWanderのサーバー経由にするDNSプロファイルをインストールし、Appleの位置情報照会サービスをブロックします。この照会がブロックされるとiOSは補正できなくなり、遠くへのテレポートが安定します。遠距離テレポートの「ずれ」専用の機能です。";
"stabilizer.warning.header" = "最初にお読みください";
"stabilizer.warning.beta" = "ベータかつ実験的です。すべての端末やiOSバージョンで効果があるとは限りません。";
"stabilizer.warning.dns" = "インストール中は、すべてのDNSがWanderのサーバーを経由します。Appleのサービス（iCloud、マップ、App Store、探す）に影響することがあります。";
"stabilizer.warning.off" = "使い終わったらオフにしてください。";
"stabilizer.warning.error12" = "これは「エラー12」を解決しません。それについてはエラー12のヘルプ（設定 → ヘルプ → 位置情報を検出できません）をご覧ください。";
"stabilizer.signin.needed" = "これを設定するには、Wanderアカウントにサインインしてください。";
"stabilizer.signin.button" = "サインイン";
"stabilizer.install.fetching" = "プロファイルを準備しています…";
