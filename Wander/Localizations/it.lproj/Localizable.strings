/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "Posizione non rilevata? (Errore 12)";
"error12.intro" = "Il messaggio «Impossibile rilevare la posizione (12)» di Pokémon GO significa che il gioco non ha ottenuto un fix GPS pulito. Wander rende già fluido il tuo movimento per non interferire con il gioco: questi passaggi risolvono il resto.";
"error12.step.location_on.title" = "Attiva Localizzazione";
"error12.step.location_on.detail" = "Impostazioni iPhone → Privacy e sicurezza → Localizzazione → Attiva, e imposta Pokémon GO → Durante l'uso dell'app. La localizzazione deve essere attiva affinché la posizione inserita raggiunga il gioco.";
"error12.step.refresh.title" = "Dopo un teletrasporto, aggiorna la posizione";
"error12.step.refresh.detail" = "Disattiva la localizzazione per ~3 secondi, poi riattivala (Impostazioni → Privacy e sicurezza → Localizzazione). Così costringi iOS a ottenere un fix nuovo nel tuo nuovo punto.";
"error12.step.cooldown.title" = "Rispetta il tempo di recupero dopo un'INTERAZIONE";
"error12.step.cooldown.detail" = "Il timer di recupero viene avviato dalle azioni — catturare un Pokémon, girare un PokéStop, dare una bacca, combattere, piazzare in una palestra — non dal teletrasporto in sé. Puoi quindi teletrasportarti liberamente, ma aspetta la fine del tempo di recupero prima dell'interazione successiva.";
"error12.step.smooth.title" = "Muoviti in modo fluido; niente teletrasporti rapidi";
"error12.step.smooth.detail" = "Se l'Errore 12 compare mentre ti muovi, fermati, aspetta qualche secondo che la posizione si stabilizzi, poi continua. Evita una raffica di piccoli teletrasporti.";
"error12.step.keep_running.title" = "Tieni Wander in esecuzione";
"error12.step.keep_running.detail" = "Tieni l'app aperta con il tunnel connesso mentre giochi: se il tunnel cade, il gioco perde subito la posizione.";
"error12.cooldown.header" = "Tempo di recupero dell'interazione per distanza";
"error12.cooldown.disclaimer" = "Stime della community, non valori ufficiali di Niantic.";
"error12.footer.discord" = "Ancora bloccato? Scrivicelo nel canale Discord #bug-reports.";
"stabilizer.title" = "Stabilizzatore a lunga distanza (Beta)";
"stabilizer.intro" = "Sperimentale. Aiuta un teletrasporto LONTANO a restare stabile invece di tornare indietro.";
"stabilizer.what.header" = "Cosa fa";
"stabilizer.what.body" = "Quando ti teletrasporti molto lontano (più di circa 20 km), iOS a volte riporta la tua posizione verso dove ti trovi davvero — usando il Wi-Fi e le celle telefoniche vicine — così un punto lontano va alla deriva o scatta indietro.\n\nQuesta funzione installa un profilo DNS che instrada il tuo DNS attraverso il server di Wander, bloccando il servizio di ricerca posizione di Apple. Con quella ricerca bloccata, iOS non può correggerti, quindi un teletrasporto lontano resta stabile. È solo per la DERIVA dei teletrasporti lontani.";
"stabilizer.warning.header" = "Leggi prima questo";
"stabilizer.warning.beta" = "Beta e sperimentale: potrebbe non aiutare su ogni dispositivo o versione di iOS.";
"stabilizer.warning.dns" = "Mentre è installato, TUTTO il tuo DNS passa attraverso il server di Wander. Può influire sui servizi Apple (iCloud, Mappe, App Store, Dov'è).";
"stabilizer.warning.off" = "Disattivalo quando hai finito.";
"stabilizer.warning.error12" = "Questo NON risolve l'«Errore 12». Per quello, vedi la guida all'Errore 12 (Impostazioni → Aiuto → Posizione non rilevata).";
"stabilizer.signin.needed" = "Accedi al tuo account Wander per configurare questa funzione.";
"stabilizer.signin.button" = "Accedi";
"stabilizer.install.fetching" = "Preparazione del profilo…";
"stabilizer.install.button" = "Installa profilo";
"stabilizer.next.header" = "Passaggi successivi";
"stabilizer.next.body" = "Safari sta scaricando il profilo. Poi:\n\n1. Impostazioni → Profilo scaricato → Installa (iOS potrebbe chiedere il codice).\n\n2. Dopo l'installazione: Impostazioni → Generali → VPN e gestione dispositivi → DNS → assicurati che «Wander Long-Distance Stabilizer» sia selezionato.\n\n3. Poi disattiva la localizzazione per circa 3 secondi e riattivala.";
"stabilizer.remove.header" = "Disattiva / rimuovi";
"stabilizer.remove.body" = "Impostazioni → Generali → VPN e gestione dispositivi → tocca «Wander Long-Distance Stabilizer (Beta)» → Rimuovi profilo.\n\nRimuovilo ogni volta che non usi teletrasporti lontani: instrada tutto il tuo DNS attraverso il server di Wander, quindi lasciarlo attivo può influire sui servizi Apple.";
