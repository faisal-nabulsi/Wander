/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "Location not detected? (Error 12)";
"error12.intro" = "Pokémon GO's 'Failed to detect location (12)' means the game didn't get a clean GPS fix. Wander already smooths your movement so it won't fight the game — these steps fix the rest.";
"error12.step.location_on.title" = "Turn Location Services ON";
"error12.step.location_on.detail" = "iPhone Settings → Privacy & Security → Location Services → ON, and set Pokémon GO → While Using the App. Location Services must be on for the injected location to reach the game.";
"error12.step.refresh.title" = "After you teleport, refresh the fix";
"error12.step.refresh.detail" = "Toggle Location Services off for ~3 seconds, then back on (Settings → Privacy & Security → Location Services). This forces iOS to grab a fresh fix at your new spot.";
"error12.step.cooldown.title" = "Respect the cooldown after INTERACTING";
"error12.step.cooldown.detail" = "The cooldown timer is started by actions — catching a Pokémon, spinning a stop, feeding a berry, battling, dropping in a gym — not by teleporting itself. So you can teleport freely, but wait out the cooldown before your next interaction.";
"error12.step.smooth.title" = "Move smoothly; don't rapid-teleport";
"error12.step.smooth.detail" = "If Error 12 pops while moving, stop, wait a few seconds for the fix to settle, then continue. Avoid a flurry of tiny teleports.";
"error12.step.keep_running.title" = "Keep Wander running";
"error12.step.keep_running.detail" = "Keep the app open with the tunnel connected while you play — if the tunnel drops, the game instantly loses the fix.";
"error12.cooldown.header" = "Interaction cooldown by distance";
"error12.cooldown.disclaimer" = "Community estimates, not official Niantic values.";
"error12.footer.discord" = "Still stuck? Tell us in the Discord #bug-reports channel.";

/* Error 12 help — error taxonomy ("which error is it?") */
"error12.taxonomy.header" = "Which error are you seeing?";
"error12.taxonomy.err11.title" = "\"Failed to detect location (11)\" — no location at all";
"error12.taxonomy.err11.detail" = "Error 11 means the game is getting NO location stream — the tunnel/connection dropped, so nothing is reaching Pokémon GO. Fix: make sure Wander is open with the tunnel connected, reconnect it, then reopen Pokémon GO.";
"error12.taxonomy.err12.title" = "\"Failed to detect location (12)\" — a bad or jumpy stream";
"error12.taxonomy.err12.detail" = "Error 12 means the location IS arriving but looks inconsistent to the game. Wander already smooths this on its side (a single writer for your movement). Remaining user-side fixes: set Pokémon GO's Location to Always + Precise; try the airplane-mode trick (Airplane Mode ON, connect the tunnel, then Wi-Fi back on) for a clean fix right after a teleport. On iOS 26, if the location keeps snapping back, the community reports a reboot clears the cached real location that the usual toggles no longer clear — not guaranteed, but worth a try.";
"error12.taxonomy.auth.title" = "\"Unable to authenticate\" — a login problem, not a GPS one";
"error12.taxonomy.auth.detail" = "This one isn't about location. Log into Pokémon GO BEFORE connecting the tunnel: sign in while you're still on your real GPS, then connect the tunnel and teleport.";

/* Error 12 help — plain-language ban ladder */
"error12.ban.header" = "The ban ladder, in plain language";
"error12.ban.intro" = "If you rush, Niantic responds in steps. Knowing the ladder keeps you calm — most of what people call a \"ban\" is just a cooldown.";
"error12.ban.softban.title" = "Soft ban / cooldown";
"error12.ban.softban.detail" = "Pokémon flee, PokéStops give you nothing, for anywhere from a few minutes to about an hour. This is not a real ban — just wait it out. Respect the cooldown after teleporting (see the cooldown table above).";
"error12.ban.strike1.title" = "Strike 1 — shadowban / \"research quest\" warning";
"error12.ban.strike1.detail" = "About 7–14 days of degraded catches — no rares show up for you. Play legit and lightly for the duration; it lifts on its own.";
"error12.ban.strike23.title" = "Strikes 2 & 3 — suspension, then permanent ban";
"error12.ban.strike23.detail" = "Further strikes escalate to temporary suspensions and finally a permanent ban. Slow down: real cooldowns, no rapid long-distance hops.";
"error12.ban.caveat" = "A sudden wave of fleeing Pokémon can be a Niantic-side bug, not necessarily a ban on you.";
"error12.ban.notvpn" = "Wander's tunnel is Apple's on-device developer tunnel — it is NOT an IP-VPN and does not change your IP address.";

