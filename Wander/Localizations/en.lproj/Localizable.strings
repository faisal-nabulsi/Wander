/* Tunnel connection help sheet */
"tunnel.title" = "Tunnel won't connect?";
"tunnel.intro" = "The tunnel is what carries Wander's location to your device. If LocalDevVPN won't connect or keeps dropping, the game loses its fix. These steps get it connected and keep it up.";
"tunnel.step.foreground.title" = "Keep Wander in the foreground";
"tunnel.step.foreground.detail" = "The tunnel needs Wander open and on screen while it connects. If you swipe Wander away or lock the phone before it's up, the connection can fail. Open Wander first, then connect.";
"tunnel.step.wifi.title" = "Connect on Wi-Fi";
"tunnel.step.wifi.detail" = "The tunnel is most reliable over Wi-Fi. Join a Wi-Fi network, then open LocalDevVPN and connect. If it connects on Wi-Fi, you can usually stay connected after switching Wi-Fi off.";
"tunnel.step.airplane.title" = "No Wi-Fi? Use the airplane-mode-first trick";
"tunnel.step.airplane.detail" = "Turn Airplane Mode ON, then open LocalDevVPN and connect the tunnel, then turn Wi-Fi back on. This brings the tunnel up cleanly without a Wi-Fi network to start.";
"tunnel.step.memory.title" = "Free up memory if it keeps dropping";
"tunnel.step.memory.detail" = "Low memory or too many apps in the background can make iOS drop the tunnel. Close some background apps (and Pokémon GO if it's a heavy session), then reconnect.";
"tunnel.step.reconnect.title" = "Clean reconnect";
"tunnel.step.reconnect.detail" = "If the tunnel is stuck, disconnect it in LocalDevVPN, make sure Wander is open, then connect again. If it still won't come up, reopen LocalDevVPN and Wander and try the steps above in order.";
"tunnel.notvpn.header" = "What this tunnel is";
"tunnel.notvpn.body" = "This is Apple's on-device developer tunnel — not an IP-VPN. It doesn't change your IP address, route your web traffic, or hide anything on the network. It only carries Wander's location to your device on this phone.";
"tunnel.footer.discord" = "Still can't connect? Tell us in the Discord #bug-reports channel.";
"settings.help.tunnel" = "Tunnel won't connect?";
"stabilizer.title" = "Long-distance stabilizer (Beta)";
"stabilizer.intro" = "Experimental. Helps a FAR teleport hold steady instead of drifting back.";
"stabilizer.what.header" = "What this does";
"stabilizer.what.body" = "When you teleport a long way (more than about 20 km), iOS sometimes pulls your location back toward where you really are — using nearby Wi-Fi and cell towers — so a far spot drifts or snaps back.\n\nThis feature installs a DNS profile that routes your DNS through Wander's server, which blocks Apple's location-lookup service. With that lookup blocked, iOS can't correct you, so a far teleport holds steady. It's for far-teleport DRIFT only.";
"stabilizer.warning.header" = "Read this first";
"stabilizer.warning.beta" = "Beta & experimental — may not help on every device or iOS version.";
"stabilizer.warning.dns" = "While installed, ALL your DNS goes through Wander's server. It can affect Apple services (iCloud, Maps, App Store, Find My).";
"stabilizer.warning.off" = "Turn it OFF when you're done.";
"stabilizer.warning.error12" = "This does NOT fix 'Error 12'. For that, see the Error 12 help (Settings → Help → Location not detected).";
"stabilizer.signin.needed" = "Sign in to your Wander account to set this up.";
"stabilizer.signin.button" = "Sign in";
"stabilizer.install.fetching" = "Preparing profile…";
"stabilizer.install.button" = "Install profile";
"stabilizer.next.header" = "Next steps";
"stabilizer.next.body" = "Safari is downloading the profile. Then:\n\n1. Settings → Profile Downloaded → Install (iOS may ask for your passcode).\n\n2. After installing: Settings → General → VPN & Device Management → DNS → make sure 'Wander Long-Distance Stabilizer' is selected.\n\n3. Then toggle Location Services off for about 3 seconds and back on.";
"stabilizer.remove.header" = "Turn it off / remove";
"stabilizer.remove.body" = "Settings → General → VPN & Device Management → tap 'Wander Long-Distance Stabilizer (Beta)' → Remove Profile.\n\nRemove it whenever you're not using far teleports — it routes all your DNS through Wander's server, so leaving it on can affect Apple services.";
