/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "Не удаётся определить местоположение? (Ошибка 12)";
"error12.intro" = "Сообщение Pokémon GO «Не удалось определить местоположение (12)» означает, что игра не получила чёткий сигнал GPS. Wander уже сглаживает ваше перемещение, чтобы не мешать игре, — эти шаги решают остальное.";
"error12.step.location_on.title" = "Включите Службы геолокации";
"error12.step.location_on.detail" = "Настройки iPhone → Конфиденциальность и безопасность → Службы геолокации → Вкл., и задайте для Pokémon GO → При использовании приложения. Службы геолокации должны быть включены, чтобы подставленное местоположение доходило до игры.";
"error12.step.refresh.title" = "После телепортации обновите местоположение";
"error12.step.refresh.detail" = "Выключите Службы геолокации примерно на 3 секунды, затем снова включите (Настройки → Конфиденциальность и безопасность → Службы геолокации). Это заставит iOS получить свежее местоположение в новой точке.";
"error12.step.cooldown.title" = "Соблюдайте перезарядку после ВЗАИМОДЕЙСТВИЯ";
"error12.step.cooldown.detail" = "Таймер перезарядки запускается действиями — поимкой покемона, вращением стопа, кормлением ягодой, боем, установкой в зале, — а не самой телепортацией. Так что телепортироваться можно свободно, но перед следующим взаимодействием дождитесь окончания перезарядки.";
"error12.step.smooth.title" = "Двигайтесь плавно; не телепортируйтесь часто";
"error12.step.smooth.detail" = "Если Ошибка 12 появляется при движении, остановитесь, подождите несколько секунд, пока местоположение устоится, затем продолжайте. Избегайте череды мелких телепортаций.";
"error12.step.keep_running.title" = "Держите Wander запущенным";
"error12.step.keep_running.detail" = "Держите приложение открытым, а туннель подключённым во время игры — если туннель обрывается, игра мгновенно теряет местоположение.";
"error12.cooldown.header" = "Перезарядка взаимодействия по расстоянию";
"error12.cooldown.disclaimer" = "Оценки сообщества, а не официальные значения Niantic.";
"error12.footer.discord" = "Всё ещё не получается? Напишите нам в канал #bug-reports в Discord.";
"stabilizer.title" = "Стабилизатор дальних телепортаций (бета)";
"stabilizer.intro" = "Экспериментально. Помогает ДАЛЬНЕЙ телепортации оставаться на месте, а не откатываться назад.";
"stabilizer.what.header" = "Что это даёт";
"stabilizer.what.body" = "Когда вы телепортируетесь далеко (более чем на ~20 км), iOS иногда возвращает ваше местоположение туда, где вы находитесь на самом деле, — используя ближайшие Wi-Fi и вышки связи, — из-за чего далёкая точка дрейфует или откатывается назад.\n\nЭта функция устанавливает профиль DNS, который направляет ваш DNS через сервер Wander и блокирует службу определения местоположения Apple. Когда этот запрос заблокирован, iOS не может вас скорректировать, и дальняя телепортация остаётся стабильной. Функция только для ДРЕЙФА при дальних телепортациях.";
"stabilizer.warning.header" = "Сначала прочитайте это";
"stabilizer.warning.beta" = "Бета и эксперимент — может помочь не на каждом устройстве или версии iOS.";
"stabilizer.warning.dns" = "Пока профиль установлен, ВЕСЬ ваш DNS идёт через сервер Wander. Это может повлиять на сервисы Apple (iCloud, Карты, App Store, Локатор).";
"stabilizer.warning.off" = "Выключайте его, когда закончите.";
"stabilizer.warning.error12" = "Это НЕ устраняет «Ошибку 12». Для неё смотрите справку по Ошибке 12 (Настройки → Помощь → Не удаётся определить местоположение).";
"stabilizer.signin.needed" = "Войдите в свою учётную запись Wander, чтобы настроить это.";
"stabilizer.signin.button" = "Войти";
"stabilizer.install.fetching" = "Подготовка профиля…";
"stabilizer.install.button" = "Установить профиль";
"stabilizer.next.header" = "Дальнейшие шаги";
"stabilizer.next.body" = "Safari загружает профиль. Затем:\n\n1. Настройки → Профиль загружен → Установить (iOS может запросить код-пароль).\n\n2. После установки: Настройки → Основные → VPN и управление устройством → DNS → убедитесь, что выбран «Wander Long-Distance Stabilizer».\n\n3. Затем выключите Службы геолокации примерно на 3 секунды и снова включите.";
"stabilizer.remove.header" = "Выключить / удалить";
