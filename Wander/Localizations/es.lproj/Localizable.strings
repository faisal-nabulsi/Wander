/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "¿No se detecta la ubicación? (Error 12)";
"error12.intro" = "El mensaje «No se pudo detectar la ubicación (12)» de Pokémon GO significa que el juego no obtuvo una señal de GPS limpia. Wander ya suaviza tu movimiento para no interferir con el juego; estos pasos solucionan el resto.";
"error12.step.location_on.title" = "Activa Localización";
"error12.step.location_on.detail" = "Ajustes del iPhone → Privacidad y seguridad → Localización → Activada, y configura Pokémon GO → Al usar la app. La localización debe estar activada para que la ubicación inyectada llegue al juego.";
"error12.step.refresh.title" = "Después de teletransportarte, actualiza la ubicación";
"error12.step.refresh.detail" = "Desactiva Localización durante ~3 segundos y vuelve a activarla (Ajustes → Privacidad y seguridad → Localización). Así obligas a iOS a obtener una señal nueva en tu nuevo punto.";
"error12.step.cooldown.title" = "Respeta el tiempo de espera tras INTERACTUAR";
"error12.step.cooldown.detail" = "El temporizador de espera lo inician las acciones: atrapar un Pokémon, girar una poképarada, dar una baya, combatir, colocar en un gimnasio; no el teletransporte en sí. Así que puedes teletransportarte libremente, pero espera a que termine el tiempo de espera antes de tu siguiente interacción.";
"error12.step.smooth.title" = "Muévete con suavidad; no te teletransportes rápido";
"error12.step.smooth.detail" = "Si aparece el Error 12 mientras te mueves, detente, espera unos segundos a que la ubicación se asiente y continúa. Evita una ráfaga de teletransportes diminutos.";
"error12.step.keep_running.title" = "Mantén Wander en marcha";
"error12.step.keep_running.detail" = "Mantén la app abierta con el túnel conectado mientras juegas: si el túnel se cae, el juego pierde la ubicación al instante.";
"error12.cooldown.header" = "Tiempo de espera de interacción por distancia";
"error12.cooldown.disclaimer" = "Estimaciones de la comunidad, no valores oficiales de Niantic.";
"error12.footer.discord" = "¿Sigues atascado? Cuéntanoslo en el canal #bug-reports de Discord.";
"stabilizer.title" = "Estabilizador de larga distancia (Beta)";
"stabilizer.intro" = "Experimental. Ayuda a que un teletransporte LEJANO se mantenga estable en lugar de volver a su sitio.";
"stabilizer.what.header" = "Qué hace";
"stabilizer.what.body" = "Cuando te teletransportas muy lejos (más de unos 20 km), iOS a veces devuelve tu ubicación hacia donde estás realmente, usando el Wi-Fi y las torres de telefonía cercanas, así que un punto lejano se desvía o vuelve de golpe.\n\nEsta función instala un perfil de DNS que enruta tu DNS a través del servidor de Wander, lo que bloquea el servicio de búsqueda de ubicación de Apple. Con esa búsqueda bloqueada, iOS no puede corregirte, así que un teletransporte lejano se mantiene estable. Es solo para la DESVIACIÓN de los teletransportes lejanos.";
"stabilizer.warning.header" = "Lee esto primero";
"stabilizer.warning.beta" = "Beta y experimental: puede que no funcione en todos los dispositivos o versiones de iOS.";
"stabilizer.warning.dns" = "Mientras esté instalado, TODO tu DNS pasa por el servidor de Wander. Puede afectar a los servicios de Apple (iCloud, Mapas, App Store, Buscar).";
"stabilizer.warning.off" = "Desactívalo cuando termines.";
"stabilizer.warning.error12" = "Esto NO soluciona el «Error 12». Para eso, consulta la ayuda del Error 12 (Ajustes → Ayuda → No se detecta la ubicación).";
"stabilizer.signin.needed" = "Inicia sesión en tu cuenta de Wander para configurar esto.";
"stabilizer.signin.button" = "Iniciar sesión";
"stabilizer.install.fetching" = "Preparando el perfil…";
"stabilizer.install.button" = "Instalar perfil";
"stabilizer.next.header" = "Pasos siguientes";
"stabilizer.next.body" = "Safari está descargando el perfil. Después:\n\n1. Ajustes → Perfil descargado → Instalar (iOS puede pedirte tu código).\n\n2. Tras instalarlo: Ajustes → General → VPN y gestión de dispositivos → DNS → asegúrate de que «Wander Long-Distance Stabilizer» esté seleccionado.\n\n3. Luego desactiva Localización unos 3 segundos y vuelve a activarla.";
"stabilizer.remove.header" = "Desactivar / eliminar";
"stabilizer.remove.body" = "Ajustes → General → VPN y gestión de dispositivos → toca «Wander Long-Distance Stabilizer (Beta)» → Eliminar perfil.\n\nElimínalo siempre que no uses teletransportes lejanos: enruta todo tu DNS a través del servidor de Wander, así que dejarlo activado puede afectar a los servicios de Apple.";
"stabilizer.error.offline" = "Necesitas conexión a internet para configurar esto.";
"stabilizer.error.build" = "No se pudo crear la solicitud. Inténtalo de nuevo.";
