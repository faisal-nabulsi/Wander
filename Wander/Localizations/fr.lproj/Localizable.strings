/* Error 12 help + Long-distance stabilizer (added 2026-07) */
"error12.title" = "Position non détectée ? (Erreur 12)";
"error12.intro" = "Le message « Impossible de détecter la position (12) » de Pokémon GO signifie que le jeu n'a pas obtenu de position GPS nette. Wander lisse déjà vos déplacements pour ne pas gêner le jeu ; ces étapes règlent le reste.";
"error12.step.location_on.title" = "Activez la Localisation";
"error12.step.location_on.detail" = "Réglages de l'iPhone → Confidentialité et sécurité → Service de localisation → Activé, et réglez Pokémon GO → Lorsque l'app est active. La localisation doit être activée pour que la position injectée parvienne au jeu.";
"error12.step.refresh.title" = "Après un téléport, actualisez la position";
"error12.step.refresh.detail" = "Désactivez la localisation pendant ~3 secondes, puis réactivez-la (Réglages → Confidentialité et sécurité → Service de localisation). Cela force iOS à obtenir une nouvelle position à votre nouvel emplacement.";
"error12.step.cooldown.title" = "Respectez le temps de recharge après une INTERACTION";
"error12.step.cooldown.detail" = "Le minuteur de recharge est déclenché par des actions — attraper un Pokémon, faire tourner un PokéStop, donner une baie, combattre, placer dans une arène — et non par le téléport lui-même. Vous pouvez donc vous téléporter librement, mais attendez la fin du temps de recharge avant votre prochaine interaction.";
"error12.step.smooth.title" = "Déplacez-vous en douceur ; pas de téléports rapides";
"error12.step.smooth.detail" = "Si l'Erreur 12 apparaît en mouvement, arrêtez-vous, attendez quelques secondes que la position se stabilise, puis continuez. Évitez une rafale de minuscules téléports.";
"error12.step.keep_running.title" = "Gardez Wander en marche";
"error12.step.keep_running.detail" = "Gardez l'app ouverte avec le tunnel connecté pendant que vous jouez : si le tunnel se coupe, le jeu perd aussitôt la position.";
"error12.cooldown.header" = "Temps de recharge d'interaction selon la distance";
"error12.cooldown.disclaimer" = "Estimations de la communauté, pas des valeurs officielles de Niantic.";
"error12.footer.discord" = "Toujours bloqué ? Dites-le-nous sur le canal Discord #bug-reports.";
"stabilizer.title" = "Stabilisateur longue distance (bêta)";
"stabilizer.intro" = "Expérimental. Aide un téléport LOINTAIN à rester stable au lieu de revenir en arrière.";
"stabilizer.what.header" = "Ce que ça fait";
"stabilizer.what.body" = "Quand vous vous téléportez très loin (plus de 20 km environ), iOS ramène parfois votre position vers l'endroit où vous êtes réellement — à l'aide du Wi-Fi et des antennes-relais à proximité — de sorte qu'un lieu lointain dérive ou revient d'un coup.\n\nCette fonction installe un profil DNS qui achemine votre DNS via le serveur de Wander, ce qui bloque le service de localisation d'Apple. Ce service bloqué, iOS ne peut plus vous corriger : un téléport lointain reste stable. C'est uniquement pour la DÉRIVE des téléports lointains.";
"stabilizer.warning.header" = "À lire d'abord";
"stabilizer.warning.beta" = "Bêta et expérimental — peut ne pas aider sur tous les appareils ou toutes les versions d'iOS.";
"stabilizer.warning.dns" = "Une fois installé, TOUT votre DNS passe par le serveur de Wander. Cela peut affecter les services Apple (iCloud, Plans, App Store, Localiser).";
"stabilizer.warning.off" = "Désactivez-le quand vous avez terminé.";
"stabilizer.warning.error12" = "Cela ne corrige PAS l'« Erreur 12 ». Pour cela, consultez l'aide sur l'Erreur 12 (Réglages → Aide → Position non détectée).";
"stabilizer.signin.needed" = "Connectez-vous à votre compte Wander pour configurer cela.";
"stabilizer.signin.button" = "Se connecter";
"stabilizer.install.fetching" = "Préparation du profil…";
"stabilizer.install.button" = "Installer le profil";
"stabilizer.next.header" = "Étapes suivantes";
"stabilizer.next.body" = "Safari télécharge le profil. Ensuite :\n\n1. Réglages → Profil téléchargé → Installer (iOS peut demander votre code).\n\n2. Après l'installation : Réglages → Général → VPN et gestion de l'appareil → DNS → vérifiez que « Wander Long-Distance Stabilizer » est sélectionné.\n\n3. Désactivez ensuite la localisation pendant environ 3 secondes, puis réactivez-la.";
"stabilizer.remove.header" = "Désactiver / supprimer";
"stabilizer.remove.body" = "Réglages → Général → VPN et gestion de l'appareil → touchez « Wander Long-Distance Stabilizer (Beta) » → Supprimer le profil.\n\nSupprimez-le dès que vous n'utilisez plus les téléports lointains : il achemine tout votre DNS via le serveur de Wander, donc le laisser actif peut affecter les services Apple.";
"stabilizer.error.offline" = "Vous avez besoin d'une connexion internet pour configurer cela.";
